modules = ["nodejs-20", "python-3.11"]
[nix]
channel = "stable-25_05"

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "EXPO_PACKAGER_PROXY_URL=https://$REPLIT_DEV_DOMAIN ./node_modules/.bin/expo start --web --port 5000"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 60000

[userenv]

[userenv.shared]
EXPO_PUBLIC_SUPABASE_URL = "REPLACE_ME"
EXPO_PUBLIC_SUPABASE_ANON_KEY = "REPLACE_ME"
EXPO_PUBLIC_ELEVENLABS_AGENT_ID = "REPLACE_ME"
EXPO_PUBLIC_ELEVENLABS_VOICE_ID = "REPLACE_ME"
EMAIL_FROM = "product@romeojuliet.love"
EMAIL_FROM_NAME = "Romeo & Juliet"
APP_URL = "https://romeojuliet.love"
OPENROUTER_MODEL = "openai/gpt-oss-120b:free"
EXPO_PUBLIC_ELEVENLABS_API_KEY = "REPLACE_ME"
