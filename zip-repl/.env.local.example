EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_ELEVENLABS_AGENT_ID=your-agent-id

# Optional — used by voice features
EXPO_PUBLIC_ELEVENLABS_VOICE_ID=your-voice-id

# Supabase Auth → Redirect URLs must include:
#   rj-app://auth/callback
#   http://localhost:5000/auth/callback  (Expo web dev — Metro runs on port 5000)
#   https://your-domain/auth/callback      (production web)
