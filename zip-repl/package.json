{
  "name": "rj-app",
  "version": "0.1.0",
  "main": "expo-router/entry",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "start": "expo start --localhost",
    "start:lan": "expo start --lan",
    "start:tunnel": "expo start --tunnel",
    "web": "expo start --web --localhost",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "doctor": "expo-doctor",
    "lint": "eslint .",
    "test": "jest --watchAll=false",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@elevenlabs/react-native": "^1.2.3",
    "@expo-google-fonts/caveat": "^0.4.2",
    "@expo-google-fonts/cormorant-garamond": "^0.4.1",
    "@expo-google-fonts/eb-garamond": "^0.4.2",
    "@expo-google-fonts/jetbrains-mono": "^0.4.1",
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "^3.1.1",
    "@supabase/supabase-js": "^2.45.0",
    "@tanstack/react-query": "^5.51.0",
    "base64-arraybuffer": "^1.0.2",
    "expo": "~54.0.35",
    "expo-auth-session": "~7.0.11",
    "expo-av": "~16.0.8",
    "expo-clipboard": "^57.0.0",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-dev-client": "~6.0.21",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.18",
    "expo-web-browser": "~15.0.11",
    "react": "19.1.4",
    "react-dom": "19.1.4",
    "react-native": "^0.81.6",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.12.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.2",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "^0.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@expo/ngrok": "^4.1.3",
    "@jest/globals": "^30.4.1",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.5.0",
    "@types/react": "~19.1.10",
    "eas-cli": "^19.1.0",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~10.0.0",
    "expo-doctor": "^1.17.11",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "react-test-renderer": "19.0.0",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "react-native",
    "setupFilesAfterEnv": [
      "@testing-library/jest-native/extend-expect"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|react-native-url-polyfill|expo|expo-.*|@expo/.*|@supabase/.*)/)"
    ]
  },
  "private": true
}
